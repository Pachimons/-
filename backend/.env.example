# AI 对话 API（OpenAI 兼容接口，推荐 bltcy.ai）
AI_API_KEY=your_api_key_here
AI_API_BASE=https://api.bltcy.ai/v1
AI_MODEL=gemini-3.1-pro-preview

# 图像生成 API (nano-banana-2, 兼容 OpenAI DALL-E 格式)
IMAGE_API_KEY=your_api_key_here
IMAGE_API_BASE=https://api.bltcy.ai/v1
IMAGE_MODEL=nano-banana-2

# HTTP 代理（如果需要通过代理访问 API）
HTTP_PROXY=

# 数据库 (SQLite)
DATABASE_URL=sqlite:///./villa_ai.db

# 上传文件存储路径
UPLOAD_DIR=./uploads
